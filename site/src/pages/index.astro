---
import "../styles/global.css";
import data from "../data/cookbook.json";

const BENCHMARK_URL = "https://evilmartians.com/#pmf-compass";
const CONTACT_URL = "https://evilmartians.com/contact-us";
const REPO_URL = "https://github.com/evilmartians/devtools-pmf";
const ISSUE_URL = `${REPO_URL}/issues/new?template=add-data-point.yml`;
const SITE_URL = "https://devtools-pmf.netlify.app";
const NOINDEX = true;
const OG_IMAGE = `${SITE_URL}/og.png`;

const getUsers = data.tracks.filter((t) => t.group === "Get users");
const grow = data.tracks.filter((t) => t.group === "Convert & grow");
const tierClass = (t) => (t || "estimated").toLowerCase();
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        {NOINDEX && <meta name="robots" content="noindex, nofollow" />}
        <title>
            The DevTools Cookbook — what 67 devtools companies did to hit PMF
        </title>
        <meta
            name="description"
            content={`${data.stats.recipes} sourced, source-checked plays real developer-tools, infrastructure, and security companies used to reach product-market fit. Filter by your goal; each is a transferable lesson. By Evil Martians.`}
        />
        <link rel="canonical" href={SITE_URL + "/"} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={SITE_URL + "/"} />
        <meta property="og:title" content="The DevTools Cookbook" />
        <meta
            property="og:description"
            content={`${data.stats.recipes} sourced plays real devtools companies used to hit product-market fit. Filter by your goal.`}
        />
        <meta property="og:image" content={OG_IMAGE} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="The DevTools Cookbook" />
        <meta
            name="twitter:description"
            content={`${data.stats.recipes} sourced plays real devtools companies used to hit product-market fit.`}
        />
        <meta name="twitter:image" content={OG_IMAGE} />
        <link
            rel="preload"
            href="/fonts/grotesk-expanded-ultrablack.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/grotesk-regular.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/grotesk-expanded-bold.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/martian-mono-700.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
    </head>
    <body>
        <!-- ====================== HERO ====================== -->
        <header class="hero">
            <div class="sky" aria-hidden="true">
                <div class="stars"></div>
                <div class="sun"></div>
                <div class="grid"></div>
                <div class="haze"></div>
            </div>
            <div class="hero-inner wrap">
                <p class="kicker">Vol. 2026 · Evil Martians</p>
                <h1 class="cover-title">
                    <span class="ct-small">The DevTools</span>
                    <span class="ct-big foil">Cookbook</span>
                </h1>
                <p class="cover-sub mono">
                    What {data.stats.companies} devtools companies did to reach product-market
                    fit
                </p>
                <div class="stats">
                    <div class="stat">
                        <span class="snum">{data.stats.recipes}</span><span
                            class="slabel mono">Recipes</span
                        >
                    </div>
                    <div class="stat">
                        <span class="snum">{data.stats.companies}</span><span
                            class="slabel mono">Companies</span
                        >
                    </div>
                    <div class="stat">
                        <span class="snum">{data.stats.tactics}</span><span
                            class="slabel mono">Tactics</span
                        >
                    </div>
                </div>
                <div class="cta">
                    <a class="btn btn-primary" href="#recipes"
                        >Browse {data.stats.recipes} plays →</a
                    >
                    <a class="btn btn-ghost" href={BENCHMARK_URL}
                        >Benchmark your company →</a
                    >
                </div>
            </div>
            <div class="scroll-cue mono" aria-hidden="true">
                ▾ open the book
            </div>
        </header>

        <main>
            <!-- ====================== FOREWORD ====================== -->
            <section class="foreword wrap">
                <p class="kicker">Foreword</p>
                <h2 class="section-title">Each recipe is a play you can run</h2>
                <div class="fw-grid">
                    <p class="fw-lede">
                        <span class="dropcap">T</span>he move that worked is
                        usually buried in a conference talk, an S-1 footnote, or
                        a five-year-old blog post. We dug it out, generalized it
                        into a play you can run, and cited it. Each recipe names
                        the company that ran it and, in the <strong
                            >when it works</strong
                        > line, tells you when it does not, because every company
                        here is a survivor and the honest question is whether the
                        play fits <em>you</em>.
                    </p>
                    <div class="legend">
                        <p class="legend-h mono">Provenance</p>
                        <div class="legend-row">
                            <span class="stamp verified">Verified</span><span
                                >Primary source: filing, official post, or a
                                named spokesperson on record.</span
                            >
                        </div>
                        <div class="legend-row">
                            <span class="stamp reported">Reported</span><span
                                >A single credible secondary source, e.g. trade
                                journalism.</span
                            >
                        </div>
                        <div class="legend-row">
                            <span class="stamp estimated">Estimated</span><span
                                >Widely reported across secondary accounts; no
                                single primary link.</span
                            >
                        </div>
                    </div>
                </div>
            </section>

            <!-- ====================== RECORDS & BENCHMARKS ====================== -->
            <section class="board wrap" id="leaderboard">
                <p class="kicker">Leaderboard</p>
                <h2 class="section-title">Records &amp; benchmarks</h2>
                <p class="appendix-lede">
                    Where the verified numbers land. The numbered cards link to
                    the plays that produced each figure.
                </p>
                <div class="boards">
                    <div class="board-col">
                        <h3 class="board-h mono">{data.leaderboards.nrr.label}</h3>
                        <ol class="board-list">
                            {data.leaderboards.nrr.rows.map((row) => (
                                <li class="board-row">
                                    <span class="board-rank mono">
                                        {String(row.rank).padStart(2, "0")}
                                    </span>
                                    <span class="board-co">{row.company}</span>
                                    <span class="board-tags mono">
                                        {row.gtm} · {row.cat}
                                    </span>
                                    <span
                                        class={`board-fig t-${row.tier.toLowerCase()}`}
                                        title={row.value}
                                    >
                                        {row.figure}
                                    </span>
                                    {row.period && (
                                        <span class="board-period mono">{row.period}</span>
                                    )}
                                    {row.cards.length > 0 && (
                                        <span class="board-cards">
                                            {row.cards.map((c) => (
                                                <a
                                                    class="play-chip"
                                                    href={`#${c.anchor}`}
                                                    data-anchor={c.anchor}
                                                    title={`#${c.no} · ${c.track} — ${c.title}`}
                                                >
                                                    {c.no}
                                                </a>
                                            ))}
                                        </span>
                                    )}
                                </li>
                            ))}
                        </ol>
                        <p class="board-note">{data.leaderboards.nrr.note}</p>
                    </div>
                </div>
            </section>

            <!-- ====================== RECIPES (filter -> deck) ====================== -->
            <section id="recipes" class="recipes">
                <div class="wrap">
                    <p class="kicker">The Recipes</p>
                    <h2 class="section-title">Find your recipe</h2>
                    <p class="recipes-lede">
                        Pick what you're trying to do, narrow by your specifics,
                        then flip through the matching plays.
                    </p>

                    <div class="filterbar">
                        <div class="frow">
                            <span class="flabel mono">Get users</span>
                            <div class="fchips">
                                {
                                    getUsers.map((t) => (
                                        <button
                                            class="fchip"
                                            data-facet="track"
                                            data-val={t.track}
                                            type="button"
                                        >
                                            {t.track}
                                            <sup>{t.count}</sup>
                                        </button>
                                    ))
                                }
                            </div>
                        </div>
                        <div class="frow">
                            <span class="flabel mono">Grow &amp; keep</span>
                            <div class="fchips">
                                {
                                    grow.map((t) => (
                                        <button
                                            class="fchip"
                                            data-facet="track"
                                            data-val={t.track}
                                            type="button"
                                        >
                                            {t.track}
                                            <sup>{t.count}</sup>
                                        </button>
                                    ))
                                }
                            </div>
                        </div>
                        <div class="frow">
                            <span class="flabel mono">Motion</span>
                            <div class="fchips">
                                {
                                    data.motions.map((m) => (
                                        <button
                                            class="fchip"
                                            data-facet="gtm"
                                            data-val={m}
                                            type="button"
                                        >
                                            {m}
                                        </button>
                                    ))
                                }
                            </div>
                        </div>
                        <div class="frow">
                            <span class="flabel mono">Category</span>
                            <div class="fchips">
                                {
                                    data.categories.map((c) => (
                                        <button
                                            class="fchip"
                                            data-facet="cat"
                                            data-val={c.key}
                                            type="button"
                                        >
                                            {c.label}
                                        </button>
                                    ))
                                }
                            </div>
                        </div>
                    </div>

                    <div class="controls">
                        <input
                            id="search"
                            class="search"
                            type="search"
                            placeholder="Search plays, companies, tactics…"
                            autocomplete="off"
                            aria-label="Search recipes"
                        />
                        <div class="controls-right">
                            <span
                                id="count"
                                class="mono"
                                role="status"
                                aria-live="polite"></span>
                            <button
                                id="clear"
                                class="clearbtn mono"
                                type="button"
                                hidden>reset ✕</button
                            >
                        </div>
                    </div>
                    <p
                        id="synth"
                        class="synth mono"
                        role="status"
                        aria-live="polite"
                        aria-atomic="true"
                        hidden
                    >
                    </p>
                </div>

                <div class="deckwrap">
                    <div class="deck-rail" id="deck-rail">
                        {
                            data.recipes.map((r) => {
                                const anchor = `${r.company
                                    .toLowerCase()
                                    .replace(/[^a-z0-9]+/g, "-")
                                    .replace(/(^-|-$)/g, "")}-${r.no}`;
                                return (
                                    <article
                                        id={anchor}
                                        class="card"
                                        data-id={r.id}
                                        data-track={r.track}
                                        data-gtm={r.gtm}
                                        data-cat={r.sub_industry}
                                        data-tags={r.tags.join(" ")}
                                    >
                                        <div class="c-top">
                                            <span class="rno mono">
                                                No. {r.no}
                                            </span>
                                            <span class="c-track mono">
                                                {r.track}
                                            </span>
                                            <span
                                                class={`stamp ${tierClass(r.tier)}`}
                                            >
                                                {r.tier}
                                            </span>
                                        </div>
                                        <h3 class="ctitle">{r.title}</h3>
                                        <div class="c-body">
                                            <div class="c-col">
                                                <p class="c-co mono">
                                                    How{" "}
                                                    <a
                                                        href={`https://${r.url}`}
                                                        target="_blank"
                                                        rel="noopener"
                                                    >
                                                        {r.company}
                                                    </a>{" "}
                                                    did it
                                                    <span class="rgtm">
                                                        {r.gtm}
                                                    </span>
                                                </p>
                                                <p class="c-sum">{r.summary}</p>
                                                {r.when_it_works && (
                                                    <p class="c-when">
                                                        <span class="lbl mono">
                                                            When it works
                                                        </span>{" "}
                                                        {r.when_it_works}
                                                    </p>
                                                )}
                                                {r.companyMetrics.length >
                                                    0 && (
                                                    <div
                                                        class="facts"
                                                        aria-label="Company benchmarks"
                                                    >
                                                        {r.companyMetrics.map(
                                                            (f) => (
                                                                <div
                                                                    class={`fact t-${f.tier.toLowerCase()}`}
                                                                    title={
                                                                        f.tier
                                                                    }
                                                                >
                                                                    <span class="fact-n">
                                                                        {
                                                                            f.figure
                                                                        }
                                                                    </span>
                                                                    <span class="fact-l mono">
                                                                        {
                                                                            f.label
                                                                        }
                                                                    </span>
                                                                    {f.qualifier && (
                                                                        <span class="fact-q">
                                                                            {
                                                                                f.qualifier
                                                                            }
                                                                        </span>
                                                                    )}
                                                                </div>
                                                            ),
                                                        )}
                                                    </div>
                                                )}
                                            </div>
                                            <div class="c-col c-col-r">
                                                {r.learning && (
                                                    <div class="c-learn">
                                                        <span class="c-tab mono">
                                                            Play
                                                        </span>
                                                        <p>{r.learning}</p>
                                                    </div>
                                                )}
                                                <div class="c-split">
                                                    {r.result && (
                                                        <div class="c-cell c-result">
                                                            <span class="c-tab mono">
                                                                Result
                                                            </span>
                                                            <p>{r.result}</p>
                                                        </div>
                                                    )}
                                                    {r.tradeoff && (
                                                        <div class="c-cell c-cost">
                                                            <span class="c-tab mono">
                                                                Cost
                                                            </span>
                                                            <p>{r.tradeoff}</p>
                                                        </div>
                                                    )}
                                                </div>
                                            </div>
                                        </div>
                                        <div class="c-foot">
                                            <div class="rtags">
                                                {r.tags.map((t) => (
                                                    <button
                                                        class="tag-mini"
                                                        data-tag={t}
                                                        type="button"
                                                    >
                                                        {t}
                                                    </button>
                                                ))}
                                            </div>
                                            {r.source_url ? (
                                                <a
                                                    class="rsrc mono"
                                                    href={r.source_url}
                                                    target="_blank"
                                                    rel="noopener"
                                                    title={r.attribution}
                                                >
                                                    Source ↗
                                                </a>
                                            ) : (
                                                <span
                                                    class="rsrc mono dim"
                                                    title={r.attribution}
                                                >
                                                    no direct link
                                                </span>
                                            )}
                                        </div>
                                    </article>
                                );
                            })
                        }
                    </div>
                    <div class="deck-nav">
                        <button
                            id="prev"
                            class="deck-arrow"
                            type="button"
                            aria-label="Previous play">←</button
                        >
                        <span
                            id="pos"
                            class="mono"
                            role="status"
                            aria-live="polite"></span>
                        <button
                            id="next"
                            class="deck-arrow"
                            type="button"
                            aria-label="Next play">→</button
                        >
                        <button
                            id="mute"
                            class="deck-snd mono"
                            type="button"
                            aria-pressed="true"
                            aria-label="Toggle flip sound"
                            title="Flip sound">♪</button
                        >
                    </div>
                    <div class="swipe-hint" id="swipe-hint" aria-hidden="true">
                        Swipe <span class="arrows">→</span>
                    </div>
                </div>

                <div class="wrap">
                    <p id="empty" class="empty" hidden>
                        No plays match that combination. <button
                            id="empty-clear"
                            class="linklike">Reset the filters.</button
                        >
                    </p>
                    <p class="caveat">
                        These are plays that worked for these companies. Treat
                        them as leads to test, not guarantees.
                    </p>
                    <div class="cta-band">
                        <p class="cta-band-h">Stuck on one of these moves?</p>
                        <p class="cta-band-sub">
                            The Martians who compiled this cookbook work on
                            developer-tools go-to-market for a living. Bring us
                            your goal, we'll help you run the play.
                        </p>
                        <a class="btn btn-primary" href={CONTACT_URL}
                            >Work with Evil Martians →</a
                        >
                    </div>
                </div>
            </section>

            <!-- ====================== TACTIC CROSS-REFERENCE ====================== -->
            <section class="appendix wrap">
                <p class="kicker">Appendix A</p>
                <h2 class="section-title">Or browse by tactic</h2>
                <p class="appendix-lede">
                    Every recipe is cross-referenced. Pick a tactic or channel
                    to filter the book.
                </p>
                <div class="tagcloud">
                    {
                        data.tags.map((t) => (
                            <button
                                class="tagchip"
                                data-facet="tag"
                                data-val={t.tag}
                                type="button"
                            >
                                {t.tag}
                                <sup>{t.count}</sup>
                            </button>
                        ))
                    }
                </div>
            </section>
        </main>

        <!-- ====================== FOOTER ====================== -->
        <footer class="foot">
            <div class="wrap foot-inner">
                <div>
                    <p class="foot-title">The DevTools Cookbook</p>
                    <p class="foot-sub mono">
                        Part of the <a href={REPO_URL}>DevTools PMF</a> dataset ·
                        updated {data.generatedAt}
                    </p>
                </div>
                <nav class="foot-nav mono">
                    <a href={BENCHMARK_URL}>Test your company →</a>
                    <a href={ISSUE_URL}>Contribute a recipe</a>
                    <a href={REPO_URL}>Star on GitHub</a>
                </nav>
                <p class="foot-mark mono">
                    Made by <a href="https://evilmartians.com">Evil Martians</a> ·
                    data CC BY 4.0
                </p>
            </div>
        </footer>

        <script>
            const cards = Array.from(document.querySelectorAll(".card"));
            const textIndex = new WeakMap();
            for (const el of cards)
                textIndex.set(el, el.textContent.toLowerCase());
            const facetBtns = Array.from(
                document.querySelectorAll("[data-facet]"),
            );
            const search = document.getElementById("search");
            const countEl = document.getElementById("count");
            const synthEl = document.getElementById("synth");
            const clearBtn = document.getElementById("clear");
            const emptyEl = document.getElementById("empty");
            const rail = document.getElementById("deck-rail");
            const posEl = document.getElementById("pos");
            const total = cards.length;

            const TRACK_VERB = {
                "Open-source": "drive open-source adoption",
                "Launches & build-in-public": "win attention with launches",
                "Community & DevRel": "grow your community",
                "Content & SEO": "pull demand with content",
                "Integrations & ecosystem": "grow through integrations",
                "Word-of-mouth & outbound":
                    "spread by word of mouth and outreach",
                Activation: "activate users",
                Conversion: "convert to paid",
                Retention: "keep customers",
                Expansion: "expand accounts",
                Revenue: "grow revenue",
            };
            const CAT_LABEL = {
                tooling: "tooling",
                infra: "infrastructure",
                security: "security",
            };
            const state = { track: null, gtm: null, cat: null, tag: null };
            let query = "";

            function matches(el) {
                if (state.track && el.dataset.track !== state.track)
                    return false;
                if (state.gtm && el.dataset.gtm !== state.gtm) return false;
                if (state.cat && el.dataset.cat !== state.cat) return false;
                if (
                    state.tag &&
                    !el.dataset.tags.split(" ").includes(state.tag)
                )
                    return false;
                if (query && !textIndex.get(el).includes(query)) return false;
                return true;
            }
            function sentence(n) {
                const verb = state.track ? TRACK_VERB[state.track] : null;
                let s = verb
                    ? `${n} ${n === 1 ? "play" : "plays"} to ${verb}`
                    : `${n} ${n === 1 ? "play" : "plays"}`;
                const who = [];
                if (state.gtm) who.push(state.gtm);
                if (state.cat) who.push(CAT_LABEL[state.cat]);
                if (who.length) s += ` for ${who.join(" ")} companies`;
                if (state.tag) s += ` · tactic: ${state.tag}`;
                return s;
            }
            const visibleCards = () =>
                cards.filter((c) => !c.classList.contains("is-hidden"));
            function focusedIndex(vis) {
                if (!vis.length) return -1;
                const center = rail.scrollLeft + rail.clientWidth / 2;
                let idx = 0,
                    best = Infinity;
                for (let i = 0; i < vis.length; i++) {
                    const c = vis[i],
                        cc = c.offsetLeft + c.offsetWidth / 2,
                        d = Math.abs(cc - center);
                    if (d < best) {
                        best = d;
                        idx = i;
                    }
                }
                return idx;
            }
            // ---- ASMR card-flip sound (synthesized via Web Audio, no asset) ----
            let audioCtx = null,
                noiseBuf = null,
                lastFlipAt = 0;
            let soundOn = localStorage.getItem("deckSound") !== "off";
            const muteBtn = document.getElementById("mute");
            function initAudio() {
                if (audioCtx) {
                    if (audioCtx.state === "suspended") audioCtx.resume();
                    return;
                }
                const AC = window.AudioContext || window.webkitAudioContext;
                if (!AC) return;
                audioCtx = new AC();
                if (audioCtx.state === "suspended") audioCtx.resume();
                // pre-render a dry "autumn leaves" crackle: a faint noise floor plus hundreds of
                // short decaying micro-grains, which is what gives the irregular rustle texture
                const sr = audioCtx.sampleRate,
                    n = Math.floor(sr * 1.6);
                noiseBuf = audioCtx.createBuffer(1, n, sr);
                const d = noiseBuf.getChannelData(0);
                for (let i = 0; i < n; i++)
                    d[i] = (Math.random() * 2 - 1) * 0.04;
                const grains = 1100;
                for (let k = 0; k < grains; k++) {
                    const start = (Math.random() * (n - 300)) | 0;
                    const glen = 24 + ((Math.random() * 110) | 0);
                    const amp = 0.35 + Math.random() * 0.6;
                    for (let j = 0; j < glen; j++) {
                        const env = 1 - j / glen;
                        d[start + j] +=
                            (Math.random() * 2 - 1) * amp * env * env;
                    }
                }
            }
            function flipSound() {
                if (!soundOn || !audioCtx) return;
                const now = audioCtx.currentTime;
                if (now - lastFlipAt < 0.05) return; // avoid stacking on fast scroll
                lastFlipAt = now;
                if (audioCtx.state === "suspended") audioCtx.resume();
                // play a random slice of the crackle buffer (each flip differs) through a dry
                // band-pass, no low-end, with a gentle swell so it rustles rather than slaps
                const src = audioCtx.createBufferSource();
                src.buffer = noiseBuf;
                src.playbackRate.value = 0.85 + Math.random() * 0.35;
                const bp = audioCtx.createBiquadFilter();
                bp.type = "bandpass";
                bp.frequency.value = 2400;
                bp.Q.value = 0.5;
                const hp = audioCtx.createBiquadFilter();
                hp.type = "highpass";
                hp.frequency.value = 800; // dry, no rumble or slap
                const g = audioCtx.createGain();
                g.gain.setValueAtTime(0.0001, now);
                g.gain.linearRampToValueAtTime(0.033, now + 0.04);
                g.gain.exponentialRampToValueAtTime(0.0004, now + 0.3);
                src.connect(bp);
                bp.connect(hp);
                hp.connect(g);
                g.connect(audioCtx.destination);
                src.start(now, Math.random() * 1.2, 0.36);
            }
            function paintMute() {
                muteBtn.textContent = soundOn ? "♪" : "♪̶";
                muteBtn.setAttribute("aria-pressed", String(soundOn));
                muteBtn.classList.toggle("is-off", !soundOn);
            }
            muteBtn.addEventListener("click", () => {
                initAudio();
                soundOn = !soundOn;
                localStorage.setItem("deckSound", soundOn ? "on" : "off");
                paintMute();
                if (soundOn) flipSound(); // little confirmation chirp
            });
            paintMute();
            // sound fires only when the centered card actually changes (scroll/nav)
            let soundFocusId = null;
            function maybeFlipSound() {
                const vis = visibleCards();
                if (!vis.length) return;
                const id = vis[focusedIndex(vis)].id;
                if (soundFocusId === null) {
                    soundFocusId = id;
                    return;
                }
                if (id !== soundFocusId) {
                    soundFocusId = id;
                    flipSound();
                }
            }

            let lastHashId = "";
            function syncHash(id) {
                if (!id || id === lastHashId) return;
                lastHashId = id;
                history.replaceState(null, "", "#" + id);
            }
            function updatePos() {
                const vis = visibleCards();
                if (!vis.length) {
                    posEl.textContent = "";
                    return;
                }
                const idx = focusedIndex(vis);
                posEl.textContent = `${idx + 1} / ${vis.length}`;
                syncHash(vis[idx].id);
            }
            // Center a card using layout coords (transform-independent, so no overshoot).
            // Native smooth scroll + mandatory scroll-snap fight each other (a premature
            // scrollend restores snap mid-flight and yanks the rail back), so we animate
            // scrollLeft ourselves with snap suspended and restore it only when we land.
            let focusIdx = 0,
                programmatic = false,
                animId = null;
            const easeOutCubic = (p) => 1 - Math.pow(1 - p, 3);
            function animateScrollTo(target, done) {
                cancelAnimationFrame(animId);
                const start = rail.scrollLeft;
                const dist = target - start;
                if (Math.abs(dist) < 1) {
                    rail.scrollLeft = target;
                    done && done();
                    return;
                }
                const dur = Math.min(560, 200 + Math.abs(dist) * 0.22);
                let t0 = null;
                function step(ts) {
                    if (t0 === null) t0 = ts;
                    const p = Math.min(1, (ts - t0) / dur);
                    rail.scrollLeft = start + dist * easeOutCubic(p);
                    if (p < 1) animId = requestAnimationFrame(step);
                    else {
                        rail.scrollLeft = target;
                        done && done();
                    }
                }
                animId = requestAnimationFrame(step);
            }
            function centerCard(el, smooth) {
                const target = Math.max(
                    0,
                    el.offsetLeft - (rail.clientWidth - el.offsetWidth) / 2,
                );
                if (smooth) {
                    programmatic = true;
                    rail.style.scrollSnapType = "none"; // keep snap from fighting the animation
                    animateScrollTo(target, () => {
                        rail.style.scrollSnapType = ""; // restored exactly on a snap point: no jump
                        programmatic = false;
                    });
                } else {
                    // Land exactly on centre. Two things fight a plain assignment here:
                    // CSS scroll-behavior:smooth would animate it, and the cards' scroll-
                    // driven scale/rotate animation means mandatory snap reads a half-scaled
                    // box and lands on the wrong neighbour. Freeze the transform, suspend
                    // smooth + snap, set the layout centre, then restore (snap now agrees).
                    rail.classList.add("snapping");
                    rail.style.scrollBehavior = "auto";
                    rail.style.scrollSnapType = "none";
                    rail.scrollLeft = Math.max(
                        0,
                        el.offsetLeft - (rail.clientWidth - el.offsetWidth) / 2,
                    );
                    void rail.offsetWidth; // settle at target before snap re-arms
                    rail.style.scrollSnapType = "";
                    rail.style.scrollBehavior = "";
                    void rail.offsetWidth;
                    rail.classList.remove("snapping");
                }
            }
            // when the user scrolls manually, keep our index in sync for the next key press
            rail.addEventListener("scrollend", () => {
                if (programmatic) return;
                const vis = visibleCards();
                if (vis.length) focusIdx = focusedIndex(vis);
            });
            // step from the in-flight target during rapid presses, not the mid-animation position
            function move(dir) {
                const vis = visibleCards();
                if (!vis.length) return;
                const base = programmatic ? focusIdx : focusedIndex(vis);
                focusIdx = Math.max(0, Math.min(vis.length - 1, base + dir));
                centerCard(vis[focusIdx], true);
            }
            // highlight the search term inside cards via the CSS Custom Highlight
            // API (no DOM mutation, instant to clear; degrades gracefully if absent)
            const canHighlight =
                typeof Highlight !== "undefined" && "highlights" in CSS;
            function highlightMatches() {
                if (!canHighlight) return;
                CSS.highlights.delete("search");
                if (!query || query.length < 2) return;
                const ranges = [];
                for (const card of visibleCards()) {
                    const walker = document.createTreeWalker(
                        card,
                        NodeFilter.SHOW_TEXT,
                    );
                    let node;
                    while ((node = walker.nextNode())) {
                        const text = node.nodeValue.toLowerCase();
                        let from = 0,
                            idx = text.indexOf(query);
                        while (idx !== -1) {
                            const r = document.createRange();
                            r.setStart(node, idx);
                            r.setEnd(node, idx + query.length);
                            ranges.push(r);
                            from = idx + query.length;
                            idx = text.indexOf(query, from);
                        }
                    }
                }
                if (ranges.length)
                    CSS.highlights.set("search", new Highlight(...ranges));
            }
            function apply(scrollReset) {
                let v = 0;
                for (const el of cards) {
                    const show = matches(el);
                    el.classList.toggle("is-hidden", !show);
                    if (show) v++;
                }
                for (const b of facetBtns) {
                    const on = state[b.dataset.facet] === b.dataset.val;
                    b.classList.toggle("is-active", on);
                    b.setAttribute("aria-pressed", String(on));
                }
                const active =
                    state.track || state.gtm || state.cat || state.tag || query;
                countEl.textContent = active
                    ? `${v} / ${total}`
                    : `${total} plays`;
                clearBtn.hidden = !active;
                synthEl.hidden = !active;
                synthEl.textContent = active ? "→ " + sentence(v) : "";
                emptyEl.hidden = v !== 0;
                if (scrollReset) {
                    rail.scrollLeft = 0;
                    focusIdx = 0;
                }
                updatePos();
                highlightMatches();
                // resync baselines so filtering/search doesn't fire a flip sound or misstep nav
                const vis2 = visibleCards();
                if (vis2.length) {
                    soundFocusId = vis2[focusedIndex(vis2)].id;
                    if (!scrollReset) focusIdx = focusedIndex(vis2);
                }
            }
            function setFacet(facet, val) {
                state[facet] = state[facet] === val ? null : val;
                apply(true);
                document
                    .getElementById("recipes")
                    .scrollIntoView({ behavior: "smooth", block: "start" });
            }
            facetBtns.forEach((b) =>
                b.addEventListener("click", () =>
                    setFacet(b.dataset.facet, b.dataset.val),
                ),
            );
            document
                .querySelectorAll(".tag-mini")
                .forEach((c) =>
                    c.addEventListener("click", () =>
                        setFacet("tag", c.dataset.tag),
                    ),
                );
            search.addEventListener("input", () => {
                query = search.value.trim().toLowerCase();
                apply(true);
            });
            function clearAll() {
                state.track = state.gtm = state.cat = state.tag = null;
                query = "";
                search.value = "";
                apply(true);
            }
            clearBtn.addEventListener("click", clearAll);
            document
                .getElementById("empty-clear")
                .addEventListener("click", clearAll);
            document
                .getElementById("prev")
                .addEventListener("click", () => move(-1));
            document
                .getElementById("next")
                .addEventListener("click", () => move(1));
            rail.addEventListener(
                "scroll",
                () =>
                    requestAnimationFrame(() => {
                        updatePos();
                        maybeFlipSound();
                    }),
                { passive: true },
            );
            window.addEventListener(
                "resize",
                () => requestAnimationFrame(updatePos),
                { passive: true },
            );
            // unlock the AudioContext on the first user gesture
            ["pointerdown", "keydown", "wheel", "touchstart"].forEach((ev) =>
                window.addEventListener(ev, initAudio, {
                    once: true,
                    passive: true,
                }),
            );
            document.addEventListener("keydown", (e) => {
                if (e.target && e.target.tagName === "INPUT") return;
                if (e.key === "ArrowRight") move(1);
                else if (e.key === "ArrowLeft") move(-1);
                else if (e.key === "Escape") clearAll();
            });
            apply(false);
            // mobile-only one-time swipe hint: appears when the deck scrolls into
            // view, dismisses on the first swipe (or after a few seconds), remembered
            (function swipeHintSetup() {
                const hint = document.getElementById("swipe-hint");
                if (
                    !hint ||
                    !window.matchMedia("(max-width: 640px)").matches ||
                    localStorage.getItem("deckSwipeHint") === "seen" ||
                    !("IntersectionObserver" in window)
                )
                    return;
                // reparent to <body> so position:fixed always pins to the viewport,
                // regardless of any transformed/filtered ancestor in the deck
                document.body.appendChild(hint);
                let timer = null;
                const dismiss = () => {
                    hint.classList.remove("is-on");
                    localStorage.setItem("deckSwipeHint", "seen");
                    clearTimeout(timer);
                };
                const io = new IntersectionObserver(
                    (entries) => {
                        if (entries.some((e) => e.isIntersecting)) {
                            hint.classList.add("is-on");
                            rail.addEventListener("scroll", dismiss, {
                                once: true,
                                passive: true,
                            });
                            timer = setTimeout(dismiss, 6000);
                            io.disconnect();
                        }
                    },
                    // the rail is taller than the viewport, so 0.5 can never be
                    // reached; 0.2 fires once the deck is well into view
                    { threshold: 0.2 },
                );
                io.observe(rail);
            })();
            // deep-link: if the URL names a card, center it on load. The browser's
            // own fragment scroll lands the card at a snap edge and runs after this
            // script, so we re-centre on the next frame, after fonts, and on load
            // (which fires after that native scroll) to make our centring win.
            (function deepLink() {
                const id = decodeURIComponent(location.hash.slice(1));
                if (!id) return;
                const el = cards.find(
                    (c) => c.id === id && !c.classList.contains("is-hidden"),
                );
                if (!el) return;
                function center() {
                    centerCard(el, false);
                    const vis = visibleCards();
                    focusIdx = Math.max(0, vis.indexOf(el));
                    requestAnimationFrame(updatePos);
                }
                function land() {
                    document
                        .querySelector(".deckwrap")
                        .scrollIntoView({ block: "start" });
                    center();
                    soundFocusId = el.id;
                    lastHashId = id;
                }
                requestAnimationFrame(land);
                if (document.fonts && document.fonts.ready)
                    document.fonts.ready.then(() => requestAnimationFrame(center));
                window.addEventListener("load", () => requestAnimationFrame(center), {
                    once: true,
                });
            })();
            // leaderboard play-cards jump to and center their card in the deck
            document.querySelectorAll(".play-chip").forEach((a) => {
                a.addEventListener("click", (e) => {
                    const id = a.getAttribute("data-anchor");
                    const el = id && document.getElementById(id);
                    if (!el) return; // fall back to default hash navigation
                    e.preventDefault();
                    clearAll(); // make sure the card isn't filtered out
                    document
                        .querySelector(".deckwrap")
                        .scrollIntoView({ behavior: "smooth", block: "start" });
                    requestAnimationFrame(() => {
                        const vis = visibleCards();
                        focusIdx = Math.max(0, vis.indexOf(el));
                        centerCard(el, false);
                        soundFocusId = el.id;
                        lastHashId = id;
                        history.replaceState(null, "", "#" + id);
                        requestAnimationFrame(updatePos);
                    });
                });
            });
        </script>

