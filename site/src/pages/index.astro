                        opacity: 1;
                        transform: scale(1) rotateY(0deg);
                    }
                    100% {
                        opacity: 0.38;
                        transform: scale(0.66) rotateY(52deg);
                    }
                }
            }
            /* While we programmatically centre a card, freeze the scroll-driven
               scale/rotate so mandatory snap reads the true layout box, not a
               half-scaled one, and lands on the right card. */
            .deck-rail.snapping .card {
                animation: none !important;
                transform: none !important;
            }
            /* 80s arcade neon glow on hover */
            .card:hover {
                border-color: var(--magenta);
                box-shadow:
                    0 0 0 1px var(--magenta),
                    0 0 12px rgba(255, 46, 132, 0.7),
                    0 0 34px rgba(228, 60, 12, 0.45),
                    0 0 70px rgba(255, 46, 132, 0.25),
                    0 22px 60px rgba(0, 0, 0, 0.55);
            }
            .card::after {
                content: "";
                position: absolute;
                inset: 0;
                border-radius: 12px;
                pointer-events: none;
                box-shadow:
                    inset 0 0 22px rgba(255, 46, 132, 0.18),
                    inset 0 0 1px var(--magenta);
                opacity: 0;
                transition: opacity 0.25s;
            }
            .card:hover::after {
                opacity: 1;
            }

            .c-top {
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: 0.6rem;
                margin-bottom: 0.9rem;
            }
            .rno {
                color: var(--paper-faint);
            }
            .c-track {
                color: var(--paper-faint);
                font-size: 0.58rem;
                border: 1px solid var(--line);
                padding: 0.3em 0.55em;
                border-radius: 2px;
            }
            .ctitle {
                font-family: var(--font-head);
                font-size: clamp(1.45rem, 2.2vw, 2rem);
                line-height: 1.12;
                letter-spacing: 0.005em;
                margin: 0 0 1.3rem;
                color: var(--paper);
                max-width: 30ch;
            }

            /* two-column body: narrative left, the actionable play + numbers right */
            .c-body {
                display: grid;
                grid-template-columns: 1fr 1fr;
                column-gap: clamp(2rem, 4vw, 3.2rem);
                align-items: stretch;
            }
            .c-col {
                min-width: 0;
                display: flex;
                flex-direction: column;
            }
            .c-col-r {
                position: relative;
            }
            .c-col-r::before {
                content: "";
                position: absolute;
                top: 0;
                bottom: 0;
                left: calc(-1 * clamp(1rem, 2vw, 1.6rem));
                width: 1px;
                background: var(--line);
            }

            /* ---- 80s HUD panels: Play / Result / Cost ---- */
            .c-learn {
                --ac: var(--red);
                --ac-rgb: var(--red-rgb);
                margin-bottom: 1.2rem;
            }
            .c-result {
                --ac: var(--cyan);
                --ac-rgb: var(--cyan-rgb);
            }
            .c-cost {
                --ac: var(--ember);
                --ac-rgb: var(--ember-rgb);
            }
            .c-learn,
            .c-cell {
                position: relative;
                border: 1px solid rgba(var(--ac-rgb), 0.45);
                border-radius: 4px;
                padding: 1.25rem 1.05rem 1rem;
                background: linear-gradient(
                    180deg,
                    rgba(var(--ac-rgb), 0.12),
                    rgba(var(--ac-rgb), 0.02) 60%,
                    transparent
                );
                box-shadow:
                    0 0 13px rgba(var(--ac-rgb), 0.15),
                    inset 0 0 20px rgba(var(--ac-rgb), 0.05);
            }
            /* corner tick, arcade-HUD detail */
            .c-learn::after,
            .c-cell::after {
                content: "";
                position: absolute;
                right: 6px;
                bottom: 6px;
                width: 9px;
                height: 9px;
                border-right: 1px solid rgba(var(--ac-rgb), 0.7);
                border-bottom: 1px solid rgba(var(--ac-rgb), 0.7);
            }
            /* legend tab sitting astride the top border */
            .c-tab {
                position: absolute;
                top: 0;
                left: 0.85rem;
                transform: translateY(-52%);
                padding: 0.18em 0.55em;
                background: var(--panel-bg);
                border: 1px solid rgba(var(--ac-rgb), 0.55);
                border-radius: 2px;
                font-size: 0.55rem;
                letter-spacing: 0.24em;
                text-transform: uppercase;
                color: var(--ac);
                text-shadow: 0 0 8px rgba(var(--ac-rgb), 0.9);
            }
            .lbl {
                color: var(--red);
                display: block;
                margin-bottom: 0.3rem;
                font-size: 0.58rem;
            }
            .c-learn p {
                margin: 0;
                font-size: 1.05rem;
                line-height: 1.5;
                color: var(--paper);
            }

            .c-co {
                color: var(--paper-faint);
                display: flex;
                align-items: center;
                gap: 0.5rem;
                margin: 0 0 1rem;
            }
            .c-co a {
                color: var(--cyan);
            }
            .rgtm {
                color: var(--paper-faint);
                font-size: 0.92em;
                padding: 0.1em 0.5em;
                border: 1px solid var(--line);
                border-radius: 2px;
            }

            /* big glowing number-facts, pinned to the bottom of the left column */
            .facts {
                display: flex;
                flex-wrap: wrap;
                gap: 1.1rem 1.7rem;
                margin-top: auto;
                padding-top: 1.7rem;
            }
            .fact {
                display: flex;
                flex-direction: column;
                gap: 0.18rem;
            }
            .fact-n {
                font-family: var(--font-head);
                font-size: clamp(1.6rem, 2.7vw, 2.3rem);
                line-height: 1;
                color: var(--cyan);
                text-shadow: 0 0 16px currentColor;
            }
            .fact-l {
                font-size: 0.52rem;
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: var(--paper-faint);
            }
            .fact-q {
                font-size: 0.6rem;
                color: var(--paper-dim);
                letter-spacing: 0.01em;
                max-width: 18ch;
            }
            .fact.t-verified .fact-n {
                color: var(--cyan);
            }
            .fact.t-reported .fact-n {
                color: var(--gold);
            }
            .fact.t-estimated .fact-n {
                color: var(--ember);
            }

            .c-sum {
                color: var(--paper-dim);
                font-size: 0.95rem;
                line-height: 1.55;
                margin: 0 0 1.2rem;
            }

            /* Result | Cost juxtaposed */
            .c-split {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 1rem;
                margin: 0;
            }
            .c-cell p {
                margin: 0;
                font-size: 0.85rem;
                line-height: 1.45;
                color: var(--paper-dim);
            }
            .c-result p {
                color: var(--paper);
            }

            .c-when {
                font-size: 0.82rem;
                color: var(--paper-faint);
                margin: 1.2rem 0 0;
                line-height: 1.45;
            }
            .c-when .lbl {
                color: var(--gold);
            }

            .c-foot {
                margin-top: 1.2rem;
                padding-top: 0.9rem;
                border-top: 1px solid var(--line);
                display: flex;
                justify-content: space-between;
                align-items: flex-end;
                gap: 0.8rem;
            }
            .rtags {
                display: flex;
                flex-wrap: wrap;
                gap: 0.35rem;
            }
            .tag-mini {
                font-family: var(--font-mono);
                font-size: 0.58rem;
                letter-spacing: 0.04em;
                color: var(--paper-faint);
                background: none;
                border: 1px solid var(--line);
                padding: 0.28em 0.5em;
                border-radius: 2px;
                cursor: pointer;
                transition: all 0.15s;
            }
            .tag-mini:hover {
                color: var(--paper);
                border-color: var(--magenta);
                box-shadow: 0 0 10px rgba(255, 46, 132, 0.4);
            }
            .rsrc {
                white-space: nowrap;
                font-size: 0.62rem;
            }
            .rsrc.dim {
                color: var(--paper-faint);
            }

            /* deck nav */
            .deck-nav {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 1.4rem;
                margin-top: 0.4rem;
            }
            .deck-arrow {
                font-family: var(--font-mono);
                font-size: 1.1rem;
                line-height: 1;
                color: var(--paper-dim);
                background: rgba(20, 12, 17, 0.7);
                border: 1px solid var(--line-strong);
                width: 2.6rem;
                height: 2.6rem;
                padding: 0;
                border-radius: 50%;
                cursor: pointer;
                transition: all 0.15s var(--ease);
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }
            .deck-arrow:hover {
                color: var(--paper);
                border-color: var(--magenta);
                box-shadow: 0 0 14px rgba(255, 46, 132, 0.5);
            }
            #pos {
                color: var(--paper-faint);
                min-width: 5ch;
                text-align: center;
            }
            .deck-snd {
                width: 2.6rem;
                height: 2.6rem;
                padding: 0;
                border-radius: 50%;
                cursor: pointer;
                font-size: 1rem;
                line-height: 1;
                color: var(--cyan);
                background: rgba(20, 12, 17, 0.7);
                border: 1px solid var(--line-strong);
                text-shadow: 0 0 10px rgba(var(--cyan-rgb), 0.8);
                transition: all 0.15s var(--ease);
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }
            .deck-snd:hover {
                border-color: var(--cyan);
                box-shadow: 0 0 14px rgba(var(--cyan-rgb), 0.5);
            }
            .deck-snd.is-off {
                color: var(--paper-faint);
                text-shadow: none;
            }

            /* search-term highlight (CSS Custom Highlight API): neon cyan glow */
            ::highlight(search) {
                background-color: rgba(var(--cyan-rgb), 0.32);
                color: #ecfffe;
                -webkit-text-stroke: 0.3px rgba(var(--cyan-rgb), 0.6);
                text-shadow:
                    0 0 4px rgba(var(--cyan-rgb), 1),
                    0 0 11px rgba(var(--cyan-rgb), 0.95),
                    0 0 22px rgba(var(--cyan-rgb), 0.6);
            }

            .empty {
                text-align: center;
                color: var(--paper-dim);
                padding: 3rem 0 1rem;
            }
            .caveat {
                text-align: center;
                color: var(--paper-faint);
                font-size: 0.85rem;
                margin-top: 1.5rem;
                font-style: italic;
            }
            .cta-band {
                margin-top: 3.5rem;
                padding: 2.4rem;
                text-align: center;
                border: 1px solid var(--line-strong);
                border-radius: 10px;
                background: radial-gradient(
                    120% 100% at 50% 0%,
                    rgba(228, 60, 12, 0.14),
                    rgba(20, 12, 17, 0.5)
                );
            }
            .cta-band-h {
                font-family: var(--font-head);
                text-transform: uppercase;
                font-size: clamp(1.2rem, 3vw, 1.7rem);
                letter-spacing: 0.03em;
                margin: 0 0 0.6rem;
            }
            .cta-band-sub {
                color: var(--paper-dim);
                max-width: 46ch;
                margin: 0 auto 1.6rem;
                font-size: 0.98rem;
            }
            .linklike {
                background: none;
                border: none;
                color: var(--red);
                cursor: pointer;
                font: inherit;
                text-decoration: underline;
            }

            /* ---------------- TACTIC INDEX ---------------- */
            .appendix {
                border-top: 1px solid var(--line);
            }
            .appendix-lede {
                color: var(--paper-dim);
                margin: 0.8rem 0 2rem;
                max-width: 52ch;
            }
            .tagcloud {
                display: flex;
                flex-wrap: wrap;
                gap: 0.55rem;
            }
            .tagchip {
                font-family: var(--font-mono);
                font-size: 0.72rem;
                letter-spacing: 0.06em;
                color: var(--paper-dim);
                background: rgba(20, 12, 17, 0.7);
                border: 1px solid var(--line-strong);
                padding: 0.5em 0.8em;
                border-radius: 3px;
                cursor: pointer;
                transition: all 0.15s var(--ease);
            }
            .tagchip sup {
                color: var(--red);
                margin-left: 0.3em;
                font-size: 0.7em;
            }
            .tagchip:hover {
                color: var(--paper);
                border-color: var(--red);
                transform: translateY(-1px);
            }
            .tagchip.is-active {
                background: var(--red);
                color: var(--paper);
                border-color: var(--red);
            }
            .tagchip.is-active sup {
                color: var(--paper);
            }

            /* ---------------- RECORDS & BENCHMARKS ---------------- */
            .board {
                border-top: 1px solid var(--line);
            }
            .boards {
                display: grid;
                grid-template-columns: 1fr;
                max-width: 36rem;
                margin: 1.8rem auto 0;
            }
            .board-h {
                color: var(--paper-faint);
                font-size: 0.62rem;
                letter-spacing: 0.16em;
                text-transform: uppercase;
                margin: 0 0 0.6rem;
            }
            .board-list {
                list-style: none;
                margin: 0;
                padding: 0;
            }
            .board-row {
                border-bottom: 1px solid var(--line);
                display: grid;
                grid-template-columns: 2rem 1fr auto auto;
                column-gap: 0.8rem;
                align-items: center;
                padding: 0.7rem 0.3rem;
            }
            .board-rank {
                grid-row: 1 / 3;
                color: var(--paper-faint);
                font-size: 0.82rem;
                text-align: right;
            }
            .board-row:nth-child(-n + 3) .board-rank {
                color: var(--gold);
                text-shadow: 0 0 9px rgba(246, 196, 84, 0.8);
            }
            .board-co {
                grid-column: 2;
                grid-row: 1;
                color: var(--paper);
                font-size: 0.98rem;
            }
            .board-tags {
                grid-column: 2;
                grid-row: 2;
                color: var(--paper-faint);
                font-size: 0.54rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
            }
            .board-fig {
                grid-column: 4;
                grid-row: 1;
                align-self: end;
                text-align: right;
                font-family: var(--font-head);
                font-size: 1.2rem;
                line-height: 1;
                color: var(--cyan);
                text-shadow: 0 0 13px currentColor;
            }
            .board-period {
                grid-column: 4;
                grid-row: 2;
                align-self: start;
                text-align: right;
                color: var(--paper-faint);
                font-size: 0.54rem;
                letter-spacing: 0.08em;
                text-transform: uppercase;
            }
            /* relevant plays as little numbered cards in their own column */
            .board-cards {
                grid-column: 3;
                grid-row: 1 / 3;
                align-self: center;
                display: flex;
                flex-wrap: wrap;
                justify-content: flex-end;
                gap: 0.4rem;
                margin-left: 0.4rem;
            }
            .play-chip {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-width: 2.3rem;
                height: 1.55rem;
                padding: 0 0.35rem;
                border: 1px solid var(--line-strong);
                border-radius: 3px;
                background: linear-gradient(
                    180deg,
                    rgba(var(--cyan-rgb), 0.08),
                    rgba(var(--cyan-rgb), 0.02)
                );
                box-shadow: inset 0 1px 0 rgba(246, 236, 226, 0.06);
                font-family: var(--font-mono);
                font-size: 0.6rem;
                font-weight: 700;
                letter-spacing: 0.06em;
                color: var(--paper-dim);
                transition:
                    color 0.15s,
                    border-color 0.15s,
                    box-shadow 0.15s,
                    transform 0.15s;
            }
            .play-chip:hover {
                color: var(--cyan);
                border-color: rgba(var(--cyan-rgb), 0.65);
                box-shadow: 0 0 14px rgba(var(--cyan-rgb), 0.4);
                transform: translateY(-1px);
                text-decoration: none;
            }
            .board-note {
                color: var(--paper-faint);
                font-size: 0.72rem;
                line-height: 1.45;
                font-style: italic;
                margin: 0.9rem 0 0;
            }
            @media (max-width: 640px) {
                .boards {
                    grid-template-columns: 1fr;
                    gap: 2.2rem;
                }
            }

            /* ---------------- FOOTER ---------------- */
            .foot {
                border-top: 1px solid var(--line-strong);
                padding-block: 3rem;
                background: var(--void);
            }
            .foot-inner {
                display: flex;
                flex-wrap: wrap;
                gap: 1.6rem;
                justify-content: space-between;
                align-items: center;
            }
            .foot-title {
                font-family: var(--font-head);
                text-transform: uppercase;
                letter-spacing: 0.04em;
                margin: 0;
            }
            .foot-sub {
                color: var(--paper-faint);
                margin: 0.3rem 0 0;
                font-size: 0.62rem;
            }
            .foot-nav {
                display: flex;
                gap: 1.4rem;
                flex-wrap: wrap;
            }
            .foot-nav a {
                color: var(--paper-dim);
                font-size: 0.7rem;
            }
            .foot-nav a:hover {
                color: var(--red);
            }
            .foot-mark {
                color: var(--paper-faint);
                font-size: 0.62rem;
                width: 100%;
                border-top: 1px solid var(--line);
                padding-top: 1.2rem;
            }

            @media (max-width: 860px) {
                .c-body {
                    grid-template-columns: 1fr;
                    row-gap: 1.2rem;
                }
                .c-col-r::before {
                    display: none;
                }
                .c-col-r {
                    border-top: 1px solid var(--line);
                    padding-top: 1.2rem;
                }
            }
            @media (max-width: 760px) {
                .fw-grid {
                    grid-template-columns: 1fr;
                }
                .stats {
                    gap: 1.4rem;
                }
                .frow {
                    grid-template-columns: 1fr;
                    gap: 0.4rem;
                }
                .flabel {
                    padding-top: 0;
                }
                .c-split {
                    grid-template-columns: 1fr;
                    gap: 1rem;
                }
            }
            /* mobile swipe hint: hidden on desktop, shown briefly on phones */
            .swipe-hint {
                display: none;
            }
            @media (max-width: 640px) {
                .swipe-hint {
                    position: fixed;
                    left: 50%;
                    bottom: 1.5rem;
                    transform: translateX(-50%);
                    z-index: 40;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                    padding: 0.6rem 1rem;
                    font-family: var(--font-mono);
                    font-size: 0.62rem;
                    letter-spacing: 0.14em;
                    text-transform: uppercase;
                    color: var(--paper);
                    background: rgba(20, 12, 17, 0.82);
                    -webkit-backdrop-filter: blur(6px);
                    backdrop-filter: blur(6px);
                    border: 1px solid var(--cyan);
                    border-radius: 999px;
                    box-shadow:
                        0 0 14px rgba(var(--cyan-rgb), 0.5),
                        0 6px 22px rgba(0, 0, 0, 0.55);
                    opacity: 0;
                    transition: opacity 0.45s var(--ease);
                    pointer-events: none;
                }
                .swipe-hint.is-on {
                    opacity: 1;
                }
                .swipe-hint .arrows {
                    color: var(--cyan);
                    font-size: 0.95rem;
                    line-height: 1;
                    text-shadow: 0 0 9px rgba(var(--cyan-rgb), 0.95);
                    animation: swipenudge 1.3s var(--ease) infinite;
                }
                @keyframes swipenudge {
                    0%,
                    100% {
                        transform: translateX(0);
                        opacity: 0.55;
                    }
                    50% {
                        transform: translateX(6px);
                        opacity: 1;
                    }
                }
                @media (prefers-reduced-motion: reduce) {
                    .swipe-hint .arrows {
                        animation: none;
                    }
                }
            }
            /* phones: each card is a full-screen, full-bleed panel (no 3D flip) */
            @media (max-width: 640px) {
                .deck-rail {
                    gap: 0;
                    padding: 0;
                    perspective: none;
                    align-items: flex-start;
                }
                .card {
                    flex-basis: 100vw;
                    min-height: calc(100svh - 4rem);
                    display: flex;
                    flex-direction: column;
                    border-radius: 0;
                    border-inline: 0;
                    box-shadow: none;
                    padding: 1.6rem 5vw 1.8rem;
                    animation: none !important;
                    transform: none !important;
                    opacity: 1 !important;
                }
                .c-foot {
                    margin-top: auto;
                }
            }
            @media (max-width: 540px) {
                .wrap {
                    width: 90vw;
                }
                .hero {
                    padding: 6vh 0 7vh;
                }
                .kicker {
                    letter-spacing: 0.08em;
                    font-size: 0.5rem;
                }
                .ct-small {
                    font-size: 0.95rem;
                    letter-spacing: 0.08em;
                }
                .ct-big {
                    font-size: clamp(1.4rem, 7vw, 4rem);
                    letter-spacing: -0.015em;
                }
                .cover-sub {
                    letter-spacing: 0.04em;
                    font-size: 0.52rem;
                    max-width: 32ch;
                    margin-inline: auto;
                }
                .stats {
                    gap: 0.9rem;
                    margin-top: 1.8rem;
                }
                .snum {
                    font-size: 1.55rem;
                }
                .slabel {
                    font-size: 0.5rem;
                    letter-spacing: 0.1em;
                }
                .cta {
                    gap: 0.6rem;
                    margin-top: 2rem;
                    flex-direction: column;
                    align-items: center;
                }
                .btn {
                    font-size: 0.66rem;
                    padding: 0.9em 1.1em;
                    letter-spacing: 0.08em;
                    width: 100%;
                    max-width: 300px;
                    text-align: center;
                }
                .cta-band {
                    padding: 1.6rem 1.1rem;
                }
                .cta-band-h {
                    font-size: 1.05rem;
                }
                .foot-nav {
                    gap: 0.7rem 1rem;
                }
                .foot-nav a {
                    font-size: 0.62rem;
                }
            }
        </style>
    </body>
</html>
